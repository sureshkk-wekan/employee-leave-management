# Copy to .env and set values. Do not commit .env.

# Optional: JWT signing secret. If unset, a random key is generated and saved to backend/.jwt_secret
# SECRET_KEY=your-random-secret-here

# Optional: path to JSON data file (default: backend/data.json)
# DATA_FILE=./data.json

# Optional
# DEBUG=false
# ACCESS_TOKEN_EXPIRE_MINUTES=60
